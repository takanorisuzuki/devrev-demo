# ================================
# DriveRev Backend - Environment Variables Template
# ================================
# コピーして .env を作成: cp .env.example .env

# --------------------------------
# Database Configuration
# --------------------------------
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/driverev_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=driverev_db
DB_USER=postgres
DB_PASSWORD=postgres123

# --------------------------------
# Redis Configuration
# --------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------
# Security
# --------------------------------
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------
# CORS Configuration
# --------------------------------
ALLOWED_HOSTS=["localhost", "127.0.0.1", "0.0.0.0"]
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# --------------------------------
# Email Configuration (Optional)
# --------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_USE_TLS=true

# --------------------------------
# DevRev統合設定
# --------------------------------
# ⚠️ セキュリティ重要事項:
# - 本番環境: GitHub Secretsから自動注入（.envファイルは不要）
# - ローカル開発: https://app.devrev.ai から取得して以下に設定
# - ⚠️ 絶対にGitにコミットしないこと！

# DevRev PLuG App ID (Unique App ID)
DEVREV_GLOBAL_APP_ID=your_app_id_here

# DevRev Application Access Token (AAT) - 組織全体のAdmin権限
# ⚠️ 注意: AATは非常に機密性が高い情報です
DEVREV_GLOBAL_AAT=your_aat_here_DO_NOT_COMMIT

# Session Token有効期限（時間）
DEVREV_SESSION_TOKEN_EXPIRY_HOURS=1

# DevRev API Base URL
DEVREV_API_URL=https://api.devrev.ai

# --------------------------------
# Application Settings
# --------------------------------
APP_NAME=DriveRev
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
API_PREFIX=/api/v1

# --------------------------------
# File Upload
# --------------------------------
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=/app/uploads
ASSETS_PATH=/app/assets

# --------------------------------
# Logging
# --------------------------------
LOG_LEVEL=INFO
