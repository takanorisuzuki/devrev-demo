# ==============================================
# JP Rental Car Demo - Environment Variables
# ==============================================

# --------------------------------
# Database Configuration
# --------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jp_rental_car
DB_USER=postgres
DB_PASSWORD=postgres123

# Database URL (for SQLAlchemy)
DATABASE_URL=postgresql://postgres:postgres123@postgres:5432/jp_rental_car

# --------------------------------
# Redis Configuration
# --------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --------------------------------
# JWT & Security Configuration
# --------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
BCRYPT_ROUNDS=12

# --------------------------------
# Application Configuration
# --------------------------------
APP_NAME=DriveRev
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=localhost:8000
API_PREFIX=/api/v1
BASE_PATH=/

# CORS Settings
# Development
ALLOWED_HOSTS=["localhost", "127.0.0.1", "0.0.0.0"]
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
# Production (GCE VM example)
# ALLOWED_HOSTS=["localhost", "127.0.0.1", "0.0.0.0", "34.182.56.160"]
# CORS_ORIGINS=["http://34.182.56.160:3000"]

# --------------------------------
# Email Configuration
# --------------------------------
# SMTP Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Email Templates
EMAIL_FROM=noreply@driverev.jp
EMAIL_FROM_NAME=DriveRev

# --------------------------------
# Frontend Configuration
# --------------------------------
# Development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
# Production (GCE VM example)
# NEXT_PUBLIC_API_URL=http://34.182.56.160:8000
# NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_NAME=DriveRev
NEXT_PUBLIC_DEFAULT_LOCALE=ja
NEXT_PUBLIC_SUPPORTED_LOCALES=["ja", "en"]

# Security: Test account display control
NEXT_PUBLIC_SHOW_TEST_ACCOUNTS=true

# Frontend API endpoints
NEXT_PUBLIC_API_PREFIX=/api/v1

# DevRev PLuG SDK
NEXT_PUBLIC_DEVREV_PLUG_SDK_URL=https://plug-platform.devrev.ai/static/plug-sdk.js

# Map configuration
NEXT_PUBLIC_MAP_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_MAP_CENTER_LAT=35.6762
NEXT_PUBLIC_MAP_CENTER_LNG=139.6503

# --------------------------------
# Payment Configuration
# --------------------------------
# Stripe (for demo)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Payment settings
PAYMENT_CURRENCY=JPY
TAX_RATE=0.10

# --------------------------------
# Feature Flags
# --------------------------------
# Enable/disable features for testing
ENABLE_USER_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_LOYALTY_PROGRAM=true
ENABLE_MULTILINGUAL=true
ENABLE_PAYMENT_INTEGRATION=true
ENABLE_ADMIN_PANEL=true

# --------------------------------
# Business Logic Configuration
# --------------------------------
# Reservation settings
MIN_RESERVATION_HOURS=3
MAX_RESERVATION_DAYS=30
RESERVATION_BUFFER_MINUTES=30

# Pricing settings
BASE_DAILY_RATE=5000
PREMIUM_RATE_MULTIPLIER=1.5
WEEKEND_RATE_MULTIPLIER=1.2

# Loyalty program
LOYALTY_POINTS_PER_100_YEN=1
LOYALTY_TIER_THRESHOLDS={"silver": 1000, "gold": 3000, "platinum": 8000}

# --------------------------------
# Maintenance Mode
# --------------------------------
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=サイトメンテナンス中です。しばらくお待ちください。

# ==============================================
# Copy this file to .env and update the values
# cp env.example .env
# ==============================================
